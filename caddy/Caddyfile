(forward_auth) {
	forward_auth authentik-server:9000 {
		uri /outpost.goauthentik.io/auth/caddy
		copy_headers X-Authentik-Username X-Authentik-Groups X-Authentik-Email X-Authentik-Name X-Authentik-Uid
		trusted_proxies private_ranges
	}
}

(access_log) {
	log {
		output file /data/access-{args[0]}.log {
			roll_size 25MiB
			roll_keep 7
			roll_keep_for 168h
		}
		format filter {
			request>uri query {
				hash code
				hash state
				hash session_state
			}
			wrap json
		}
	}
}

login.{$BASE_DOMAIN} {
	import access_log login

	reverse_proxy authentik-server:9000
}

n8n.{$BASE_DOMAIN} {
	import access_log n8n
	import forward_auth

	@signin path /signin /login
	redir @signin /auth/authentik/login 302

	@needs_n8n_sso {
		method GET
		not header Cookie *n8n-auth=*
		not path /auth/authentik/login /rest/* /webhook/* /webhook-test/* /form/* /form-test/* /assets/* /favicon.ico /robots.txt
	}
	redir @needs_n8n_sso /auth/authentik/login 302

	reverse_proxy n8n:5678 {
		header_up X-Authentik-SSO-Secret {$N8N_SSO_SECRET}
	}
}

hooks.{$BASE_DOMAIN} {
	import access_log hooks

	@n8n_ingress path /webhook/* /webhook-test/* /form/* /form-test/*
	handle @n8n_ingress {
		reverse_proxy n8n:5678 {
			header_up -X-Authentik-Username
			header_up -X-Authentik-Groups
			header_up -X-Authentik-Email
			header_up -X-Authentik-Name
			header_up -X-Authentik-Uid
			header_up -X-Authentik-SSO-Secret
		}
	}

	respond 404
}

vexa.{$BASE_DOMAIN} {
	import access_log vexa
	import forward_auth

	@sso path /login /auth/sso /api/auth/logout
	handle @sso {
		reverse_proxy vexa-sso:8080 {
			header_up X-Authentik-SSO-Secret {$VEXA_SSO_SECRET}
		}
	}

	handle {
		reverse_proxy vexa-lite:3000
	}
}

vexa-api.{$BASE_DOMAIN} {
	import access_log vexa-api

	reverse_proxy vexa-lite:8056
}

odoo.{$BASE_DOMAIN} {
	import access_log odoo
	import forward_auth

	@signin path /signin /login /web/login
	redir @signin /auth/authentik/login 302

	reverse_proxy odoo:8069 {
		header_up X-Authentik-SSO-Secret {$ODOO_SSO_SECRET}
	}
}

kuma.{$BASE_DOMAIN} {
	import access_log kuma
	import forward_auth

	reverse_proxy uptime-kuma:3001
}
