<odoo>
    <record id="group_society_member" model="res.groups">
        <field name="name">Member Self-Service</field>
    </record>

    <record id="group_society_project_leader" model="res.groups">
        <field name="name">Project Leader</field>
        <field name="implied_ids" eval="[(4, ref('group_society_member'))]"/>
    </record>

    <record id="group_society_project_management" model="res.groups">
        <field name="name">Project Management</field>
        <field name="implied_ids" eval="[(4, ref('group_society_project_leader'))]"/>
    </record>

    <record id="group_society_recruitment_membership" model="res.groups">
        <field name="name">Recruitment &amp; Membership Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_society_member')), (4, ref('survey.group_survey_user'))]"/>
    </record>

    <record id="group_society_admin" model="res.groups">
        <field name="name">Society Admin</field>
        <field name="implied_ids" eval="[(4, ref('group_society_project_management')), (4, ref('group_society_recruitment_membership')), (4, ref('survey.group_survey_manager'))]"/>
    </record>

    <record id="rule_society_project_member_read" model="ir.rule">
        <field name="name">Members can read visible projects or assigned undisclosed projects</field>
        <field name="model_id" ref="model_society_project"/>
        <field name="groups" eval="[(4, ref('group_society_member'))]"/>
        <field name="domain_force">['|', ('confidentiality', '!=', 'undisclosed'), ('participant_ids.partner_id', '=', user.partner_id.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_society_project_leader_write" model="ir.rule">
        <field name="name">Project leaders can manage assigned projects</field>
        <field name="model_id" ref="model_society_project"/>
        <field name="groups" eval="[(4, ref('group_society_project_leader'))]"/>
        <field name="domain_force">[('project_lead_id', '=', user.partner_id.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_society_project_management_all" model="ir.rule">
        <field name="name">Project management can access all projects</field>
        <field name="model_id" ref="model_society_project"/>
        <field name="groups" eval="[(4, ref('group_society_project_management'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_society_connected_account_own" model="ir.rule">
        <field name="name">Members can manage their own connected accounts</field>
        <field name="model_id" ref="model_society_connected_account"/>
        <field name="groups" eval="[(4, ref('group_society_member'))]"/>
        <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
    </record>

    <record id="rule_society_connected_account_admin" model="ir.rule">
        <field name="name">Admins can manage connected accounts</field>
        <field name="model_id" ref="model_society_connected_account"/>
        <field name="groups" eval="[(4, ref('group_society_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
