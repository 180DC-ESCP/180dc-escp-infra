<odoo>
    <record id="view_society_campus_list" model="ir.ui.view">
        <field name="name">society.campus.list</field>
        <field name="model">society.campus</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_society_campuses" model="ir.actions.act_window">
        <field name="name">Campuses</field>
        <field name="res_model">society.campus</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_society_role_list" model="ir.ui.view">
        <field name="name">society.role.list</field>
        <field name="model">society.role</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="track"/>
                <field name="department"/>
                <field name="seniority_rank"/>
                <field name="management_group_id"/>
            </list>
        </field>
    </record>

    <record id="view_society_role_form" model="ir.ui.view">
        <field name="name">society.role.form</field>
        <field name="model">society.role</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="track"/>
                        <field name="department"/>
                        <field name="seniority_rank"/>
                        <field name="management_group_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_society_roles" model="ir.actions.act_window">
        <field name="name">Society Roles</field>
        <field name="res_model">society.role</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_society_member_assignment_list" model="ir.ui.view">
        <field name="name">society.member.assignment.list</field>
        <field name="model">society.member.assignment</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="role_id"/>
                <field name="campus_id"/>
                <field name="is_current"/>
            </list>
        </field>
    </record>

    <record id="view_society_member_assignment_form" model="ir.ui.view">
        <field name="name">society.member.assignment.form</field>
        <field name="model">society.member.assignment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="role_id"/>
                        <field name="campus_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_society_member_assignments" model="ir.actions.act_window">
        <field name="name">Member Assignments</field>
        <field name="res_model">society.member.assignment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
